     public ServerLevel(
         MinecraftServer server,
         Executor dispatcher,
@@ -614,6 +617,28 @@ public class ServerLevel extends Level implements ServerEntityGetter, WorldGenLe
         org.bukkit.generator.ChunkGenerator gen, // CraftBukkit
