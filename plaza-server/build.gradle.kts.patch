+// Plaza start - Fix library sources jars with invalid zip entries
+// BoostedYAML 1.3.6 ships a sources jar containing "./" entries, which breaks
+// paperweight's ZipFileSystem-backed indexing. Re-package any offending jars
+// before the library indexer sees them.
+abstract class FixInvalidLibrarySources : DefaultTask() {
+    @get:InputDirectory
+    abstract val inputDir: DirectoryProperty
+
+    @get:OutputDirectory
+    abstract val outputDir: DirectoryProperty
+
+    @TaskAction
+    fun run() {
+        val input = inputDir.get().asFile.toPath()
+        val output = outputDir.get().asFile.toPath()
+        if (Files.exists(output)) {
+            Files.walk(output).use { stream ->
+                stream.sorted(Comparator.reverseOrder()).forEach { Files.deleteIfExists(it) }
+            }
+        }
+        Files.createDirectories(output)
+
+        Files.walk(input).use { stream ->
+            stream.filter { Files.isRegularFile(it) && it.fileName.toString().endsWith("-sources.jar") }
+                .forEach { jar ->
+                    val target = output.resolve(jar.fileName)
+                    if (hasInvalidEntry(jar)) {
+                        logger.lifecycle("Repackaging ${jar.fileName} to remove invalid zip entries")
+                        repackageJar(jar, target)
+                    } else {
+                        Files.copy(jar, target, StandardCopyOption.REPLACE_EXISTING)
+                    }
+                }
+        }
+    }
+
+    private fun hasInvalidEntry(jar: Path): Boolean {
+        ZipFile(jar.toFile()).use { zip ->
+            val entries = zip.entries()
+            while (entries.hasMoreElements()) {
+                val name = entries.nextElement().name
+                if (name.isEmpty() || name.split('/').any { it == "." || it == ".." }) {
+                    return true
+                }
+            }
+        }
+        return false
+    }
+
+    private fun repackageJar(input: Path, output: Path) {
+        ZipFile(input.toFile()).use { zip ->
+            ZipOutputStream(Files.newOutputStream(output)).use { zos ->
+                val entries = zip.entries()
+                while (entries.hasMoreElements()) {
+                    val entry = entries.nextElement()
+                    val name = entry.name
+                    if (name.isEmpty() || name.split('/').any { it == "." || it == ".." }) {
+                        continue
+                    }
+                    zos.putNextEntry(ZipEntry(name))
+                    zip.getInputStream(entry).use { it.copyTo(zos) }
+                    zos.closeEntry()
+                }
+            }
+        }
+    }
+}
+
+val fixInvalidLibrarySources by tasks.registering(FixInvalidLibrarySources::class) {
+    inputDir.set(tasks.named<DownloadPaperLibraries>("downloadRuntimeClasspathSources").flatMap { it.outputDir })
+    outputDir.set(layout.buildDirectory.dir("fixed-runtime-sources"))
+}
+
+tasks.named<IndexLibraryFiles>("indexLibraryFiles") {
+    libraries.setFrom(
+        fixInvalidLibrarySources.flatMap { it.outputDir },
+        tasks.named<DownloadMcLibraries>("downloadMcLibrariesSources").flatMap { it.outputDir }
+    )
+}
+// Plaza end - Fix library sources jars with invalid zip entries
 
