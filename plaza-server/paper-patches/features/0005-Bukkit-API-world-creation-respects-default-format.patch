From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: PlazaMC <dev@plazamc.org>
Date: Wed, 8 Jul 2026 10:30:00 +0200
Subject: [PATCH] Bukkit API world creation respects default format


diff --git a/src/main/java/org/bukkit/craftbukkit/CraftServer.java b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
index da49c8005592a154946750591ce082796f24dd3b..8b4350fae836449219321a5e26f816a38c7242cb 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftServer.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
@@ -1197,6 +1197,7 @@ public final class CraftServer implements Server {
             Preconditions.checkArgument(folder.isDirectory(), "File (%s) exists and isn't a folder", name);
         }
 
+        final boolean plazaExplicitGenerator = creator.generator() != null; // Plaza
         if (chunkGenerator == null) {
             chunkGenerator = this.getGenerator(name);
         }
@@ -1205,6 +1206,24 @@ public final class CraftServer implements Server {
             biomeProvider = this.getBiomeProvider(name);
         }
 
+        // Plaza start - default void generator unless explicitly specified
+        if (chunkGenerator == null) {
+            chunkGenerator = new org.plazamc.server.generator.PlazaVoidChunkGenerator();
+        }
+        // Plaza end
+
+        // Plaza start - default world format
+        final String plazaWorldFormat = org.plazamc.server.PlazaConfig.plazaWorldsWorldFormat(name);
+        if ("SLIME".equalsIgnoreCase(plazaWorldFormat) && chunkGenerator instanceof org.plazamc.server.generator.PlazaVoidChunkGenerator) {
+            final org.bukkit.World plazaWorld = org.plazamc.server.slime.PlazaSlimeWorldBootstrap.createOrLoadWorld(name, creator.environment());
+            org.plazamc.server.world.PlazaWorldShadow.create(name); // legacy folder compatibility
+            return plazaWorld;
+        }
+        if (("ANVIL".equalsIgnoreCase(plazaWorldFormat) || "LINEAR".equalsIgnoreCase(plazaWorldFormat)) && chunkGenerator instanceof org.plazamc.server.generator.PlazaVoidChunkGenerator) {
+            org.plazamc.server.world.PlazaWorldShadow.deleteIfShadow(name); // ANVIL/LINEAR own the real world folder; only stale Slime shadows are removed
+        }
+        // Plaza end
+
         ResourceKey<LevelStem> actualDimension = switch (creator.environment()) {
             case NORMAL -> LevelStem.OVERWORLD;
             case NETHER -> LevelStem.NETHER;
