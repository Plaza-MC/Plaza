#!/usr/bin/env bash
#
# JitPack git shim
#
# JitPack's default build image ships a git older than 2.17, which does not
# understand the `--prune-tags` option. paperweight's patcher calls
#   git fetch upstream --prune --prune-tags --force
# and on git < 2.17 that dies with exit code 129 ("unknown option"), hidden
# because paperweight silences stderr.
#
# This shim drops `--prune-tags` and forwards every other argument verbatim to
# the real git. For paperweight's patch application at a fixed ref, pruning
# stale tags is irrelevant, so dropping it is safe.
#
# PLAZA_REAL_GIT must point to the real git binary (set by jitpack.yml before
# this directory is prepended to PATH). It is referenced by absolute path so the
# shim does not recurse into itself.
#
# Remove this file once JitPack's image provides git >= 2.17.

set -euo pipefail

if [[ -z "${PLAZA_REAL_GIT:-}" ]]; then
  echo "plaza git shim: PLAZA_REAL_GIT is not set" >&2
  exit 127
fi

args=()
for a in "$@"; do
  if [[ "$a" == "--prune-tags" ]]; then
    continue
  fi
  args+=("$a")
done

exec "$PLAZA_REAL_GIT" ${args[@]+"${args[@]}"}
